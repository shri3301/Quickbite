{
  "name": "quickbite-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "Backend",
    "Frontend",
    "Admin"
  ],
  "scripts": {
    "build:frontend": "npm run build --workspace=Frontend",
    "build:admin": "npm run build --workspace=Admin",
    "build": "npm run build --workspace=Frontend && npm run build --workspace=Admin",
    "start": "node Backend/server.js",
    "server": "npm run server --workspace=Backend",
    "dev:frontend": "npm run dev --workspace=Frontend",
    "dev:admin": "npm run dev --workspace=Admin",
    "dev": "concurrently \"npm run server --workspace=Backend\" \"npm run dev --workspace=Frontend\" \"npm run dev --workspace=Admin\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
